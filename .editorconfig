root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.go]
indent_style = tab
indent_size = 4

[Makefile]
indent_style = tab

[*.{md,yaml,yml,json,toml}]
indent_size = 2

[*.{vue,ts,tsx,js,jsx,css,html}]
indent_size = 2

[*.proto]
indent_size = 2
