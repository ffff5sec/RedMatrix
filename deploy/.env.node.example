# RedMatrix Scan Node 部署环境变量模板（PR-S66）。
#
# 用法：
#   cp deploy/.env.node.example deploy/.env.node
#   按下方说明填，然后 docker compose -f deploy/docker-compose.node.yml up -d
#
# chmod 600 deploy/.env.node（含 RegistrationToken）

# =============================================================================
# Server 端点
# =============================================================================

# server 公开 HTTP 端点（http(s)://<PUBLIC_DOMAIN>:<port>）
# agent 用此地址：注册 token redeem、拉插件包、上报 result。
REDMATRIX_SERVER_URL=https://redmatrix.example.com

# mTLS 控制面端点；与 server compose 的 PUBLIC_GRPC_ADDR 对应。
# 必须公网可达；防火墙允许 agent 到 9090 出站。
REDMATRIX_NODE_AGENT_URL=https://redmatrix.example.com:9090

# （可选）mTLS server cert 的 SAN override；server URL 用 IP 时不需要。
# REDMATRIX_MTLS_SERVER_NAME=redmatrix.example.com

# =============================================================================
# 节点身份
# =============================================================================

# 在 server UI（SA）→ 节点管理 → 「生成注册 token」拿到的 rmnode_xxx
# 一次性，接入成功即作废；后续靠 mTLS leaf cert 持久身份。
REDMATRIX_NODE_TOKEN=rmnode_REPLACE_WITH_REGISTRATION_TOKEN

# 节点显示名；同 tenant 内唯一
REDMATRIX_NODE_NAME=node-prod-1

# =============================================================================
# 插件目录（主机路径）
# =============================================================================

# 主机上放 nmap / subfinder / httpx / nuclei / tlsx 等二进制的目录；
# compose 自动 mount 进容器 /opt/plugins 并加入 PATH。
# 不提供则 agent 只能跑内置 L1（crtsh / fofa / hunter / quake）+ mock。
PLUGIN_HOST_DIR=/opt/redmatrix/plugins

# =============================================================================
# 镜像 / 版本
# =============================================================================

NODE_VERSION=prod
# 远端 registry 用户：NODE_IMAGE=ghcr.io/your-org/redmatrix-node:v1.0.0
# NODE_IMAGE=
