# RedMatrix server 部署环境变量模板（PR-S66 更新自 PR-S19-B）。
#
# 用法：
#   cp deploy/.env.prod.example deploy/.env.prod
#   按本文件下方说明生成 4 个 base64 32-byte 密钥 + 强随机数据库密码
#   chmod 600 deploy/.env.prod
#
# 切勿提交 .env.prod 到 git！.gitignore 已忽略 deploy/.env.prod。
#
# 部分变量带 :? 即必填；未设置 docker compose up 会直接拒绝启动。

# =============================================================================
# 公开端点（节点接入 + UI 跳转）
# =============================================================================

# Web UI / API 主域；浏览器访问的入口。配 TLS 反代后是 https://<这个>
PUBLIC_DOMAIN=redmatrix.example.com

# 节点 mTLS 控制面入口；agent 用此地址连 server。
# 多节点部署时填公网可达的 host:port。
PUBLIC_GRPC_ADDR=redmatrix.example.com:9090

# MinIO 对外可达地址；presigned URL 用此 host 给 agent / 浏览器跳转。
# 若 server 与 minio 同 VPC，agent / 用户在外网，需用公网域名。
MINIO_PUBLIC_ENDPOINT=https://minio.example.com

# =============================================================================
# 4 个秘钥（base64 编码 32 字节；必须互异；生成命令见下）
# =============================================================================
#
# 生成命令（任选其一）：
#   openssl rand -base64 32
#   head -c 32 /dev/urandom | base64
#
# 任意一个泄漏：JWT_SECRET 漏 → 全用户 session 重签；ENCRYPTION_KEY 漏 →
# PG 中加密字段全暴露；AUDIT_HMAC_KEY 漏 → 审计链可伪造；BACKUP_KEY 漏 →
# 备份归档可解密。
# 建议从云厂商 secret manager 注入而非明文落盘。

JWT_SECRET=REPLACE_WITH_BASE64_32_BYTES
ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTES
AUDIT_HMAC_KEY=REPLACE_WITH_BASE64_32_BYTES
BACKUP_KEY=REPLACE_WITH_BASE64_32_BYTES

# =============================================================================
# 数据库密码（PG）
# =============================================================================
#
# 生成：openssl rand -base64 24 | tr -d /+= | head -c 24
#
# POSTGRES_ADMIN_PASSWORD：postgres 超级用户密码（initdb 用）。
# REDMATRIX_APP_PASSWORD：应用账号（业务读写）。
# REDMATRIX_MAINT_PASSWORD：维护账号（DDL 迁移）。
# 上述三个账号在首启时由 dev/init-pg/*.sql 自动建。

POSTGRES_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
REDMATRIX_APP_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
REDMATRIX_MAINT_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# =============================================================================
# Redis / MinIO
# =============================================================================

REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

MINIO_ROOT_USER=redmatrix
MINIO_ROOT_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# =============================================================================
# Bootstrap admin（仅首启用；登录后强制改密 PR-S60）
# =============================================================================

ADMIN_BOOTSTRAP_USERNAME=admin
# 至少 12 字符；首次登录后前端弹 ChangeBootstrapPasswordModal 强制改
ADMIN_BOOTSTRAP_PASSWORD=REPLACE_WITH_TEMP_PASSWORD
ADMIN_BOOTSTRAP_EMAIL=admin@example.com

# =============================================================================
# 镜像 / 版本
# =============================================================================

# server 镜像 tag；compose build server 后会产出 redmatrix-server:${SERVER_VERSION}
SERVER_VERSION=prod
# 远端 registry 用户：SERVER_IMAGE=ghcr.io/your-org/redmatrix-server:v1.0.0
# SERVER_IMAGE=

# =============================================================================
# 日志 / 调优（可选）
# =============================================================================

LOG_LEVEL=info
LOG_FORMAT=json

# =============================================================================
# 通知 SMTP（可选；不设置则 email 通道发送失败回退到 dead）
# =============================================================================

# NOTIFY_SMTP_HOST=smtp.example.com
# NOTIFY_SMTP_PORT=587
# NOTIFY_SMTP_USERNAME=notify@example.com
# NOTIFY_SMTP_PASSWORD=
# NOTIFY_SMTP_FROM=RedMatrix <notify@example.com>
# NOTIFY_SMTP_USE_TLS=true

# =============================================================================
# 插件包签名（可选；上传新插件 .rpkg 时必需）
# =============================================================================

# ed25519 签名 key（base64 编码私钥）；server 用此 key 校验 SA 上传的 .rpkg
# PLUGIN_SIGNING_KEY_ID=plugin-key-2026q2
# PLUGIN_SIGNING_KEY_BASE64=
