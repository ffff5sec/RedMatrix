# RedMatrix 生产 env 样例（PR-S19-B）。
# 复制为 .env.prod 后填实际密钥；强烈建议从 secret manager 注入而非明文。

# === 镜像 tag ===
# 默认 dev tag 是本地 build；生产可指 release：e.g. redmatrix-server:1.0.0
SERVER_IMAGE=redmatrix-server:dev

# === PG ===
POSTGRES_ADMIN_PASSWORD=__CHANGE_ME__
# dev/init-pg/01-roles.sql 建的两个角色密码（必须与 init-pg 设的一致）
REDMATRIX_APP_PASSWORD=__CHANGE_ME__
REDMATRIX_MAINT_PASSWORD=__CHANGE_ME__

# === Redis ===
REDIS_PASSWORD=__CHANGE_ME__

# === MinIO ===
MINIO_ROOT_USER=__CHANGE_ME_user__
MINIO_ROOT_PASSWORD=__CHANGE_ME__
# 公开 endpoint（presigned URL host）；生产应是公网可达域名 + Caddy 反代
MINIO_PUBLIC_ENDPOINT=minio.example.com

# === RedMatrix server ===
# JWT 签名密钥（生产 ≥ 64 字节，从 secret manager 注）
JWT_SECRET=__CHANGE_ME_at_least_64_bytes__
# AES-256 加密 key（32 字节 base64）
ENCRYPTION_KEY=__CHANGE_ME_base64_32bytes__
# Audit HMAC key（32 字节 base64）
AUDIT_HMAC_KEY=__CHANGE_ME_base64_32bytes__
# Backup key（32 字节 base64）
BACKUP_KEY=__CHANGE_ME_base64_32bytes__

# Bootstrap admin（首启用；之后必须从 UI 改密）
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=__CHANGE_ME__

# 公开域名（CORS / cookie domain / mTLS server cert SAN）
PUBLIC_DOMAIN=redmatrix.example.com

# 启用迁移（首启 true；后续滚动建议固定 true 让 schema 自动跟）
DEV_AUTO_MIGRATE=true
DEV_MODE=false
LE_STAGING=false
