# RedMatrix 本地 dev env（仅演示；生产用 secret manager）。
#
# 用法：
#   cd dev && docker compose up -d
#   set -a && source .env.dev && set +a
#   go run ../cmd/server
#
# 或：
#   export $(grep -v '^#' dev/.env.dev | xargs)
#   go run ./cmd/server

# === Storage ===
# pg：开发档用 postgres 超管做 admin（DDL 跑迁移）；后续 RLS 落地后接 redmatrix_app
# redmatrix_app / redmatrix_maintenance role 由 migration 0001 创建
PG_DSN=postgres://redmatrix_app:appdev@127.0.0.1:5432/redmatrix?sslmode=prefer
PG_DSN_MAINTENANCE=postgres://redmatrix_maintenance:maintdev@127.0.0.1:5432/redmatrix?sslmode=prefer
PG_DSN_ADMIN=postgres://postgres:dev@127.0.0.1:5432/redmatrix?sslmode=prefer

REDIS_URL=redis://127.0.0.1:6379/0

ES_URL=http://127.0.0.1:9200

MINIO_ENDPOINT=127.0.0.1:9000
MINIO_PUBLIC_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# === Public addresses（仅日志输出 / landing url 计算；演示阶段填占位）===
PUBLIC_DOMAIN=localhost
PUBLIC_GRPC_ADDR=127.0.0.1:8080
PUBLIC_MINIO_ADDR=127.0.0.1:9000

# === Crypto secrets（演示用，固定值便于复现）===
# 生产用 `openssl rand -base64 32` 各跑一遍生成
# JWT_SECRET ≥ 64 字符；其他三个必须 base64 编码的 32 字节
JWT_SECRET=devdevdevdevdevdevdevdevdevdevdevdevdevdevdevdevdevdevdevdevdev1234
ENCRYPTION_KEY=nJlkoUg+vPxNuvuqOn6V+8q2WAUYd/WrongRyIiHa68=
AUDIT_HMAC_KEY=rDZGN//3pFizNIFqK/FhNJhIkrYiAO7c2Vxl58OGlJY=
BACKUP_KEY=VGdgpAiccJY9LL4yXWzLBmdgMJwMWfGhF5GSrXMC2x8=

# === Bootstrap admin ===
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
# 留空 = 启动期生成 16 字符随机密码 + stdout 打印一次
ADMIN_BOOTSTRAP_PASSWORD=DemoBootstrapPwd1!

# === Dev flags ===
RM_AUTO_MIGRATE=true
RM_DEV_MODE=true

# === Log ===
LOG_LEVEL=info
LOG_FORMAT=json
